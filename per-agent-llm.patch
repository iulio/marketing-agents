+# PER-AGENT LLM SETTINGS ENDPOINTS
+# ================================================================
+
+@app.get("/api/settings/agent-llm")
+@require_role(["admin"])
+async def get_agent_llm():
+    """Get the current agent-LLM mapping."""
+    settings = get_agent_llm_settings()
+    return {"agent_llm_map": settings}
+
+@app.post("/api/settings/agent-llm")
+@require_role(["admin"])
+async def update_agent_llm_endpoint(request: Request, settings: dict):
+    """Update the LLM backend for a specific agent."""
+    agent = settings.get("agent")
+    backend = settings.get("backend")
+    if not agent or not backend:
+        raise HTTPException(status_code=400, detail="Missing agent or backend")
+    if agent not in ["orchestrator", "researcher", "creative", "analyst"]:
+        raise HTTPException(status_code=404, detail="Agent not found")
+    if backend not in ["local", "vertex", "claude"]:
+        raise HTTPException(status_code=400, detail="Invalid backend")
+    success = update_agent_llm(agent, backend)
+    if not success:
+        raise HTTPException(status_code=500, detail="Update failed")
+    return {"message": f"Agent '{agent}' updated to '{backend}'"}
+
+@app.get("/api/settings/agent-llm/available")
+@require_role(["admin"])
+async def get_available_llms():
+    """Get list of available LLM backends."""
+    available = ["local"]
+    try:
+        import langchain_anthropic
+        available.append("claude")
+    except ImportError:
+        pass
+    try:
+        import langchain_google_vertexai
+        available.append("vertex")
+    except ImportError:
+        pass
+    return {"available": available}
+
