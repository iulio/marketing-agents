+def get_agent_llm_settings() -> Dict[str, str]:
+    """Get agent-LLM mapping from JSON file."""
+    if os.path.exists(AGENT_LLM_SETTINGS_FILE):
+        try:
+            with open(AGENT_LLM_SETTINGS_FILE, "r") as f:
+                data = json.load(f)
+                # Ensure all keys exist
+                defaults = _get_agent_llm_defaults()
+                for key in defaults:
+                    if key not in data:
+                        data[key] = defaults[key]
+                return data
+        except Exception:
+            pass
+    return _get_agent_llm_defaults()
+
+def update_agent_llm_setting(agent: str, backend: str) -> bool:
+    """Update a single agent-LLM setting in JSON file."""
+    settings = get_agent_llm_settings()
+    settings[agent] = backend
+    os.makedirs(os.path.dirname(AGENT_LLM_SETTINGS_FILE), exist_ok=True)
+    with open(AGENT_LLM_SETTINGS_FILE, "w") as f:
+        json.dump(settings, f, indent=2)
+    return True
+
+def reset_agent_llm_settings() -> bool:
+    """Reset all agent-LLM settings to defaults."""
